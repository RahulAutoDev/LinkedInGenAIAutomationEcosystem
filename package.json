{
  "name": "linkedin-genai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'Run projects individually'",
    "lint": "npx eslint apps/dashboard/src",
    "typecheck": "npx tsc --noEmit -p apps/dashboard/tsconfig.json",
    "health-check": "node scripts/health-check.js",
    "test:e2e": "npx playwright test",
    "precommit": "npm run typecheck && npm run health-check && npm run test:e2e"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "puppeteer": "^23.11.1"
  }
}
